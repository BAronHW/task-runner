{
  "name": "example-api-service",
  "version": "1.0.0",
  "description": "A sample Node.js REST API service",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "npm run build && ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "test": "jest",
    "clean": "rimraf dist"
  },
  "keywords": [
    "node",
    "typescript",
    "express",
    "api",
    "backend"
  ],
  "author": "Example Dev",
  "license": "MIT",
  "dependencies": {
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "axios": "^1.7.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "typescript": "^5.5.3",
    "ts-node-dev": "^2.0.0",
    "eslint": "^9.6.0",
    "@typescript-eslint/parser": "^7.15.0",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "prettier": "^3.3.3",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.12",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.9",
    "rimraf": "^5.0.7"
  },
  "engines": {
    "node": ">=18"
  }
}
